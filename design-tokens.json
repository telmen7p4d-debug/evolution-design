{
  "meta": {
    "siteName": "evolution",
    "visualDirection": "dark-luxury",
    "motionLevel": 3,
    "defaultLocale": "en",
    "locales": ["en"]
  },
  "colors": {
    "brand": {
      "primary": "#FFFFFF",
      "secondary": "#0A0A0A"
    },
    "neutral": {
      "100": "#FFFFFF",
      "200": "#F5F5F5",
      "300": "#E5E5E5",
      "400": "#999999",
      "500": "#666666",
      "600": "#333333",
      "700": "#1A1A1A",
      "800": "#111111",
      "900": "#0A0A0A"
    },
    "semantic": {
      "background": "#0A0A0A",
      "foreground": "#FFFFFF",
      "card": "#1A1A1A",
      "cardForeground": "#FFFFFF",
      "popover": "#1A1A1A",
      "popoverForeground": "#FFFFFF",
      "primary": "#FFFFFF",
      "primaryForeground": "#0A0A0A",
      "secondary": "#111111",
      "secondaryForeground": "#FFFFFF",
      "muted": "#1A1A1A",
      "mutedForeground": "#666666",
      "accent": "#111111",
      "accentForeground": "#FFFFFF",
      "border": "#333333",
      "input": "#1A1A1A",
      "ring": "#FFFFFF",
      "success": "#22C55E",
      "warning": "#EAB308",
      "destructive": "#EF4444"
    }
  },
  "typography": {
    "families": {
      "display": "Inter",
      "body": "Inter",
      "mono": "Inter"
    },
    "scale": {
      "xs": 12,
      "sm": 14,
      "base": 16,
      "lg": 18,
      "xl": 20,
      "2xl": 24,
      "3xl": 28,
      "4xl": 36,
      "5xl": 48,
      "6xl": 56,
      "7xl": 72,
      "8xl": 96,
      "9xl": 120
    }
  },
  "spacing": {
    "scale": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32,
      "2xl": 48,
      "3xl": 64,
      "4xl": 80,
      "5xl": 120,
      "6xl": 160
    },
    "layout": {
      "pagePadding": [32, 48],
      "sectionPadding": [80, 120],
      "contentMaxWidth": 1440
    }
  },
  "radius": {
    "none": 0,
    "sm": 4,
    "md": 8,
    "lg": 16,
    "xl": 24,
    "full": 9999
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px rgba(0,0,0,0.3)",
    "md": "0 4px 6px rgba(0,0,0,0.4)",
    "lg": "0 10px 15px rgba(0,0,0,0.5)",
    "xl": "0 20px 25px rgba(0,0,0,0.6)"
  },
  "motion": {
    "duration": {
      "fast": 150,
      "normal": 300,
      "slow": 500
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)"
    },
    "spring_configs": {
      "default": { "stiffness": 100, "damping": 15 }
    },
    "variants": {
      "fadeIn": { "opacity": [0, 1], "duration": 300 },
      "slideUp": { "y": [20, 0], "opacity": [0, 1], "duration": 500 },
      "scaleIn": { "scale": [0.95, 1], "opacity": [0, 1], "duration": 300 }
    },
    "gsap_configs": {
      "scrollReveal": { "y": 50, "opacity": 0, "duration": 0.8, "ease": "power2.out" }
    }
  }
}
